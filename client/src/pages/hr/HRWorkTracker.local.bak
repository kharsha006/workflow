import React, { useState, useEffect } from 'react';
import api from '../../services/api';
import { useToast } from '../../hooks/useToast';

const STATS = [
  { type: 'completed', label: 'Completed', accent: '#10B981', valColor: '#065F46', status: 'Completed' },
  { type: 'inprogress', label: 'In Progress', accent: '#4F46E5', valColor: '#3730A3', status: 'In Progress' },
  { type: 'notstarted', label: 'Not Started', accent: '#9CA3AF', valColor: '#111827', status: 'Not Started' },
  { type: 'delayed', label: 'Delayed', accent: '#EF4444', valColor: '#991B1B', status: 'Delayed' },
];
const PANEL_COLORS = {
  completed: { bg: '#D1FAE5', border: '#A7F3D0', text: '#065F46', accent: '#10B981' },
  inprogress: { bg: '#EEF2FF', border: '#C7D2FE', text: '#3730A3', accent: '#4F46E5' },
  notstarted: { bg: '#F9FAFB', border: '#E5E7EB', text: '#374151', accent: '#9CA3AF' },
  delayed: { bg: '#FEE2E2', border: '#FECACA', text: '#991B1B', accent: '#EF4444' },
};
const isDelayed = (t) => t.status === 'In Progress' && (t.progress || 0) < 30;

const HRWorkTracker = () => {
  const [logs, setLogs] = useState([]);
  const [panel, setPanel] = useState(null);
  const [open, setOpen] = useState({});
  const { addToast } = useToast();

  useEffect(() => {
    api.get('/api/daily-status?date=2026-06-08').then(({ data }) => setLogs(data || [])).catch(() => addToast('Failed to load tracker', 'error'));
  }, []);

  const allTasks = logs.flatMap((l) => (l.tasks || []).map((t) => ({ ...t, emp: l.employee })));
  const counts = {
    completed: allTasks.filter((t) => t.status === 'Completed').length,
    inprogress: allTasks.filter((t) => t.status === 'In Progress').length,
    notstarted: allTasks.filter((t) => t.status === 'Not Started').length,
    delayed: allTasks.filter(isDelayed).length,
  };

  const panelRows = panel
    ? allTasks.filter((t) => (panel === 'delayed' ? isDelayed(t) : t.status === STATS.find((s) => s.type === panel).status))
    : [];

  return (
    <div className="hr-view active">
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '16px' }}>
        <div>
          <div style={{ fontFamily: "'Plus Jakarta Sans',sans-serif", fontSize: '18px', fontWeight: 700 }}>Daily Work Tracker</div>
          <div style={{ fontSize: '12px', color: '#6B7280' }}>Live task status across all employees</div>
        </div>
        <input type="date" value="2026-06-08" readOnly style={{ padding: '7px 12px', border: '1px solid #E5E7EB', borderRadius: '9px', fontSize: '12px', color: '#374151', background: '#fff', outline: 'none' }} />
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4,1fr)', gap: '12px', marginBottom: '16px' }}>
        {STATS.map((s) => {
          const active = panel === s.type;
          return (
            <div key={s.type} className="bento-card" style={{ cursor: 'pointer', border: `1.5px solid ${active ? s.accent : 'transparent'}`, transition: 'all 0.15s' }}
              onClick={() => setPanel(active ? null : s.type)}
              onMouseEnter={(e) => (e.currentTarget.style.borderColor = s.accent)}
              onMouseLeave={(e) => { if (!active) e.currentTarget.style.borderColor = 'transparent'; }}>
              <div className="bento-accent" style={{ background: s.accent }}></div>
              <div style={{ fontSize: '11px', color: '#6B7280', marginBottom: '4px', display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                <span>{s.label}</span><i className={`fas fa-chevron-down chevron-toggle ${active ? 'open' : ''}`} style={{ fontSize: '10px', color: '#9CA3AF' }}></i>
              </div>
              <div className="bento-stat-val" style={{ fontSize: '22px', color: s.valColor }}>{counts[s.type]}</div>
            </div>
          );
        })}
      </div>

      {panel && (() => {
        const col = PANEL_COLORS[panel];
        const status = STATS.find((s) => s.type === panel).status;
        return (
          <div style={{ marginBottom: '16px' }}>
            <div className="bento-card" style={{ background: col.bg, border: `1.5px solid ${col.border}`, animation: 'fadeIn 0.2s ease' }}>
              <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '14px' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}><div style={{ width: '10px', height: '10px', borderRadius: '50%', background: col.accent }}></div><span style={{ fontSize: '14px', fontWeight: 700, color: col.text }}>{status} · {panelRows.length} task{panelRows.length !== 1 ? 's' : ''}</span></div>
                <button onClick={() => setPanel(null)} style={{ padding: '4px 10px', background: '#fff', border: '1px solid #E5E7EB', borderRadius: '7px', fontSize: '11px', cursor: 'pointer', color: '#6B7280' }}>Close ×</button>
              </div>
              {panelRows.length === 0 ? (
                <div style={{ textAlign: 'center', padding: '20px', fontSize: '13px', color: '#9CA3AF' }}>No tasks with this status today.</div>
              ) : (
                <table className="hr-table" style={{ width: '100%', background: '#fff', borderRadius: '10px', overflow: 'hidden' }}>
                  <thead><tr><th>Person</th><th>Task</th><th>Progress</th><th>Last updated</th><th>Notes</th></tr></thead>
                  <tbody>
                    {panelRows.map((r, i) => (
                      <tr key={i}>
                        <td><div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}><div style={{ width: '28px', height: '28px', borderRadius: '50%', background: r.emp?.avatar?.bg, color: r.emp?.avatar?.color, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '11px', fontWeight: 600 }}>{r.emp?.avatar?.initials}</div><span style={{ fontSize: '12px', fontWeight: 500, color: '#111827' }}>{r.emp?.name}</span></div></td>
                        <td style={{ fontSize: '12px', fontWeight: 500, color: '#111827' }}>{r.task}</td>
                        <td><div style={{ display: 'flex', alignItems: 'center', gap: '6px' }}><div style={{ width: '60px', height: '5px', background: '#F3F4F6', borderRadius: '3px', overflow: 'hidden' }}><div style={{ height: '100%', background: col.accent, width: (r.progress || 0) + '%' }}></div></div><span style={{ fontSize: '11px', fontWeight: 600, color: col.text }}>{r.progress}%</span></div></td>
                        <td style={{ fontSize: '11px', color: '#6B7280' }}>{r.updated}</td>
                        <td style={{ fontSize: '11px', color: '#6B7280', fontStyle: 'italic' }}>{r.notes}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>
          </div>
        );
      })()}

      <div>
        {logs.map((l) => {
          const t = l.tasks || [];
          const prog = t.length ? Math.round(t.reduce((a, x) => a + (x.progress || 0), 0) / t.length) : 0;
          const isOpen = !!open[l._id];
          return (
            <div key={l._id} className="exp-row" style={{ marginBottom: '8px' }}>
              <div className="exp-row-hdr" onClick={() => setOpen((o) => ({ ...o, [l._id]: !o[l._id] }))}>
                <div style={{ width: '32px', height: '32px', borderRadius: '50%', background: l.employee?.avatar?.bg, color: l.employee?.avatar?.color, display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '12px', fontWeight: 600, flexShrink: 0 }}>{l.employee?.avatar?.initials}</div>
                <div style={{ flex: 1 }}><div style={{ fontSize: '13px', fontWeight: 600, color: '#111827' }}>{l.employee?.name}</div><div style={{ fontSize: '11px', color: '#6B7280' }}>{t.length} tasks today</div></div>
                <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
                  <div style={{ fontSize: '13px', fontWeight: 700, color: '#4F46E5' }}>{prog}%</div>
                  <div style={{ width: '80px', height: '5px', background: '#F3F4F6', borderRadius: '3px', overflow: 'hidden' }}><div style={{ height: '100%', background: '#4F46E5', width: prog + '%' }}></div></div>
                </div>
                <i className={`fas fa-chevron-down chevron-toggle ${isOpen ? 'open' : ''}`} style={{ fontSize: '11px', color: '#9CA3AF', marginLeft: '8px' }}></i>
              </div>
              {isOpen && (
                <div className="exp-row-body open">
                  <table className="hr-table" style={{ width: '100%' }}>
                    <thead><tr><th>Task</th><th>Status</th><th>Progress</th><th>Updated</th><th>Notes</th></tr></thead>
                    <tbody>
                      {t.map((task, i) => {
                        const stCls = task.status === 'Completed' ? 'hr-badge-green' : task.status === 'In Progress' ? 'hr-badge-blue' : 'hr-badge-red';
                        return (
                          <tr key={i}>
                            <td style={{ fontWeight: 500 }}>{task.task}</td>
                            <td><span className={`hr-badge ${stCls}`}>{task.status}</span></td>
                            <td><div style={{ display: 'flex', alignItems: 'center', gap: '6px' }}><div style={{ width: '60px', height: '5px', background: '#F3F4F6', borderRadius: '3px', overflow: 'hidden' }}><div style={{ height: '100%', background: '#4F46E5', width: (task.progress || 0) + '%' }}></div></div><span style={{ fontSize: '11px', fontWeight: 600, color: '#374151' }}>{task.progress}%</span></div></td>
                            <td style={{ fontSize: '11px', color: '#6B7280' }}>{task.updated}</td>
                            <td style={{ fontSize: '11px', color: '#6B7280', fontStyle: 'italic' }}>{task.notes}</td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
};

export default HRWorkTracker;
